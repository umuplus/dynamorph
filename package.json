{
  "name": "dynamorph",
  "version": "0.0.1",
  "description": "a minimalist toolkit for aws dynamodb",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "lint": "eslint './src/**/*.{js,ts,tsx}'",
    "test": "jest --silent",
    "test:clean": "npm run clean && npm test && npm run clean",
    "test:watch": "jest --watchAll --experimentalDecorators",
    "build": "tsc",
    "watch": "tsc -w",
    "clean": "rm -rf dist coverage"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/umuplus/dynamorph.git"
  },
  "keywords": [
    "aws",
    "dynamodb",
    "ddb"
  ],
  "author": "Umut Aydin",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/umuplus/dynamorph/issues"
  },
  "homepage": "https://github.com/umuplus/dynamorph#readme",
  "devDependencies": {
    "@types/jest": "27.4.1",
    "@types/node": "17.0.21",
    "@typescript-eslint/eslint-plugin": "5.13.0",
    "@typescript-eslint/parser": "5.13.0",
    "aws-sdk-client-mock": "0.6.0",
    "eslint": "8.10.0",
    "eslint-config-prettier": "8.5.0",
    "eslint-plugin-prettier": "4.0.0",
    "jest": "27.5.1",
    "prettier": "2.5.1",
    "sinon": "13.0.1",
    "ts-jest": "27.1.3",
    "typescript": "4.6.2"
  },
  "files": [
    "dist/**/*"
  ],
  "dependencies": {
    "@aws-sdk/client-dynamodb": "3.53.0",
    "@aws-sdk/lib-dynamodb": "3.53.0",
    "ulid": "2.3.0",
    "zod": "3.13.4"
  }
}
